---
import '../styles/globals.css';
import '@/lib/i18n.ts'; // Init i18n

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="theme-color" content="#0082c9" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<script is:inline>
			// Theme Detection
			const theme = (() => {
				if (typeof localStorage !== 'undefined' && localStorage.getItem('fileuni-theme')) {
					const saved = JSON.parse(localStorage.getItem('fileuni-theme'));
					if (saved.state.theme === 'dark' || saved.state.theme === 'light') return saved.state.theme;
				}
				return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
			})();
			document.documentElement.classList.remove('light', 'dark');
			document.documentElement.classList.add(theme);

			// Language Detection
			const lang = (() => {
				try {
					const state = localStorage.getItem('fileuni-language');
					if (state) {
						const parsed = JSON.parse(state);
						const value = parsed?.state?.language;
					if (value === 'zh' || value === 'en' || value === 'es' || value === 'de' || value === 'fr' || value === 'ru' || value === 'ja') return value;
					if (value === 'auto') {
						const base = (navigator.language.split('-')[0] || 'en').toLowerCase();
						if (base === 'zh') return 'zh';
						if (base === 'es') return 'es';
						if (base === 'de') return 'de';
						if (base === 'fr') return 'fr';
						if (base === 'ru') return 'ru';
						if (base === 'ja') return 'ja';
						return 'en';
					}
				}
				} catch (e) {}
				const saved = localStorage.getItem('fileuni-language-raw');
				if (saved) return saved;
				const base = (navigator.language.split('-')[0] || 'en').toLowerCase();
				if (base === 'zh') return 'zh';
				if (base === 'es') return 'es';
				if (base === 'de') return 'de';
				if (base === 'fr') return 'fr';
				if (base === 'ru') return 'ru';
				if (base === 'ja') return 'ja';
				return 'en';
			})();
			document.documentElement.lang = lang;
		</script>
	</head>
	<body class="bg-background text-foreground transition-colors duration-300 min-h-screen flex flex-col">
		<slot />
	</body>
</html>
