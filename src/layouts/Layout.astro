---
import '../styles/globals.css';
import '@/lib/i18n.ts'; // Init i18n

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="theme-color" content="#0082c9" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<script>
			import { initFrontendLayoutBootstrap } from '../scripts/layout-bootstrap';

			initFrontendLayoutBootstrap();
		</script>
	</head>
	<body class="bg-background text-foreground transition-colors duration-300 min-h-screen flex flex-col">
		<slot />
	</body>
</html>
